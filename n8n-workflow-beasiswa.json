    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.pesan }}",
        "options": {
          "systemMessage": "Kamu adalah asisten ekstraksi data beasiswa. Dari pesan pengguna, ekstrak IPK (angka desimal 0-4) dan pendapatan orang tua per bulan dalam Rupiah (integer). Jika user menulis 'juta', kalikan dengan 1000000. Balas HANYA dengan JSON valid tanpa markdown: {\"ipk\": number, \"pendapatan\": number}. Contoh input: 'IPK saya 3.52 dan pendapatan orang tua 4.5 juta' -> {\"ipk\": 3.52, \"pendapatan\": 4500000}"
        }
      },
      "id": "ai-agent-001",
      "name": "AI Agent Ekstraksi",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [800, 520]
    },
    {
      "parameters": {
        "jsCode": "const ai = $input.first().json;\nconst raw = ai.output || ai.text || ai.response || '{}';\nconst router = $('Router Menu & Pesan').first().json;\nconst telegramText = router.pesan || '';\n\nfunction parseFromText(text) {\n  const t = String(text).toLowerCase().replace(/,/g, '.');\n  const ipkMatch = t.match(/ipk[^0-9]*(\\d+(?:\\.\\d+)?)/) || t.match(/(\\d+(?:\\.\\d+)?)\\s*ipk/);\n  let pendapatan = null;\n  const juta = t.match(/(?:pendapatan|gaji|penghasilan)(?:\\s+orang\\s+tua)?[^0-9]*(\\d+(?:\\.\\d+)?)\\s*juta/);\n  if (juta) pendapatan = parseFloat(juta[1]) * 1_000_000;\n  if (pendapatan === null) {\n    const rp = t.match(/(?:pendapatan|gaji|penghasilan)(?:\\s+orang\\s+tua)?[^0-9]*(\\d[\\d.,]*)/);\n    if (rp) pendapatan = parseInt(rp[1].replace(/[.,]/g, ''), 10);\n  }\n  const ipk = ipkMatch ? parseFloat(ipkMatch[1]) : null;\n  if (ipk === null || pendapatan === null) return null;\n  return { ipk, pendapatan };\n}\n\nlet parsed = null;\ntry {\n  const clean = String(raw).replace(/```json|```/gi, '').trim();\n  const jsonMatch = clean.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) parsed = JSON.parse(jsonMatch[0]);\n} catch (e) {\n  parsed = null;\n}\n\nif (!parsed || parsed.ipk === undefined || parsed.pendapatan === undefined) {\n  parsed = parseFromText(telegramText) || { ipk: 0, pendapatan: 9_999_999 };\n}\n\nconst ipk = Number(parsed.ipk);\nconst pendapatan = Number(parsed.pendapatan);\nconst lolos = ipk >= 3.3 && pendapatan <= 5_000_000;\nconst chatId = router.chatId;\nconst nama = router.nama;\n\nreturn [{ json: { ipk, pendapatan, lolos, chatId, nama } }];"
      },
