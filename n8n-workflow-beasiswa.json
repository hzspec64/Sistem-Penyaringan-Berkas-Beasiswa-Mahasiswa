      "parameters": {
        "jsCode": "const msg = $input.first().json.message || {};\nconst text = (msg.text || '').trim();\nconst chatId = msg.chat?.id;\nconst nama = msg.from?.first_name || 'Mahasiswa';\n\nconst MENU = '🏠 Menu Utama';\nconst SYARAT = '📋 Syarat Beasiswa';\nconst DEMO_LOLOS = '✅ Demo Lolos (Skenario 1)';\nconst DEMO_TIDAK = '❌ Demo Tidak Lolos (Skenario 2)';\nconst BANTUAN = 'ℹ️ Bantuan';\nconst CEK_LAGI = '🔄 Cek Lagi';\nconst COBA_LAGI = '🔄 Coba Lagi';\nconst DAFTAR = '🎓 Daftar / Cek Beasiswa';\n\nlet route = 'proses';\nlet pesan = text;\n\nif (!text || text === '/start' || text === MENU || text === CEK_LAGI || text === COBA_LAGI || text === DAFTAR) {\n  route = 'menu';\n} else if (text === SYARAT) {\n  route = 'syarat';\n} else if (text === BANTUAN) {\n  route = 'bantuan';\n} else if (text === DEMO_LOLOS) {\n  route = 'proses';\n  pesan = 'IPK saya 3.52 dan pendapatan orang tua 4.5 juta.';\n} else if (text === DEMO_TIDAK) {\n  route = 'proses';\n  pesan = 'IPK saya 3.10 dan gaji orang tua 3 juta.';\n}\n\nreturn [{ json: { route, pesan, chatId, nama, textAsli: text } }];"
      },
